FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
ARG BUILD_CONFIGURATION=Release
WORKDIR /src

# Copy csproj để restore
COPY ["src/Gym.PublicAPI/Gym.PublicAPI.csproj", "src/Gym.PublicAPI/"]
COPY ["src/Gym.Application/Gym.Application.csproj", "src/Gym.Application/"]
COPY ["src/Gym.Domain/Gym.Domain.csproj", "src/Gym.Domain/"]
COPY ["src/Gym.Infrastructure/Gym.Infrastructure.csproj", "src/Gym.Infrastructure/"]

RUN dotnet restore "src/Gym.PublicAPI/Gym.PublicAPI.csproj"

# Copy full source
COPY . .

# Build đúng path
WORKDIR "/src/Gym.PublicAPI"
RUN dotnet publish "Gym.PublicAPI.csproj" -c $BUILD_CONFIGURATION -o /app/publish

# ===== Stage 3: Run =====
FROM base AS final
WORKDIR /app

